APP_NAME="E-Commerce"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Dhaka
APP_URL=http://localhost:8000

# ── Database ─────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ecommerce
DB_USERNAME=root
DB_PASSWORD=

# ── Cache / Session / Queue ──────────────────────────────────────────────
# Use 'database' for local dev, 'redis' for production
CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database

# Redis (required for Horizon, optional for cache/session)
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ─────────────────────────────────────────────────────────────────
MAIL_MAILER=log
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=you@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=noreply@chokbazar.com
# MAIL_FROM_NAME="${APP_NAME}"

# ── Search (Scout) ────────────────────────────────────────────────────────
SCOUT_DRIVER=database
# MEILISEARCH_HOST=http://127.0.0.1:7700
# MEILISEARCH_KEY=

# ── Octane (high-performance server) ─────────────────────────────────────
# OCTANE_SERVER=swoole
# OCTANE_PORT=8000

# ── Horizon (queue monitoring) ───────────────────────────────────────────
# HORIZON_DOMAIN=horizon.yourstore.com

# ── Storage / CDN ────────────────────────────────────────────────────────
# FILESYSTEM_DISK=public        # or 's3' for cloud
# ASSET_URL=https://cdn.yourstore.com

# ── Payment Gateways (Bangladesh) ───────────────────────────────────────
# Uncomment and fill in your credentials

# SSLCommerz
# SSLC_STORE_ID=
# SSLC_STORE_PASSWORD=
# SSLC_SANDBOX=true

# bKash
# BKASH_APP_KEY=
# BKASH_APP_SECRET=
# BKASH_USERNAME=
# BKASH_PASSWORD=
# BKASH_SANDBOX=true

# Nagad
# NAGAD_MERCHANT_ID=
# NAGAD_MERCHANT_NUMBER=
# NAGAD_PUBLIC_KEY=
# NAGAD_PRIVATE_KEY=
# NAGAD_SANDBOX=true

# ── Courier APIs (Bangladesh) ───────────────────────────────────────────

# Steadfast
# STEADFAST_API_KEY=
# STEADFAST_SECRET_KEY=
# STEADFAST_BASE_URL=https://portal.steadfast.com.bd/api/v1

# Pathao
# PATHAO_CLIENT_ID=
# PATHAO_CLIENT_SECRET=
# PATHAO_USERNAME=
# PATHAO_PASSWORD=
# PATHAO_BASE_URL=https://api-hermes.pathao.com

# RedX
# REDX_API_KEY=
# REDX_BASE_URL=https://openapi.redx.com.bd/v1

# ── SMS / OTP ────────────────────────────────────────────────────────────
# OTP_DRIVER=log        # log, twilio, greenweb, or sms.net
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=
# GREENWEB_API_KEY=
# SMS_NET_API_KEY=

# ── Facebook / Social ────────────────────────────────────────────────────
# FACEBOOK_PIXEL_ID=
# FACEBOOK_PAGE_ID=
# FACEBOOK_VERIFICATION_CODE=

# ── Cloudflare ──────────────────────────────────────────────────────────
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_API_TOKEN=

# ── AWS (for S3 storage) ─────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Laravel defaults ────────────────────────────────────────────────────
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database
BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
MEMCACHED_HOST=127.0.0.1
VITE_APP_NAME="${APP_NAME}"
